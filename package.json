    },
    "devDependencies": {
        "jest": "^29.7.0",
        "@playwright/test": "^1.41.0"
    },
    "jest": {
        "transform": {},
        "testEnvironment": "node",
        "testMatch": [
            "**/tests/unit/**/*.test.js"
        ]
    }
}
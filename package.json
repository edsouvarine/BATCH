    "description": "Système de batch cooking familial — Nico, Flo, Sacha, Victor",
    "type": "module",
    "scripts": {
        "dev": "python3 -m http.server 8765",
        "test": "node --experimental-vm-modules node_modules/.bin/jest --testPathPattern=tests/unit",
        "test:e2e": "playwright test tests/e2e",
